# FitBridge MVP — Airtable persistence config
# Copy to .env.local and fill in real values, then restart `npm run dev`.
# If these are unset, the app falls back to localStorage so the demo still works.

VITE_AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Optional — override default table names
VITE_AIRTABLE_TABLE_MEALS=Meals
VITE_AIRTABLE_TABLE_METRICS=BodyMetrics
VITE_AIRTABLE_TABLE_WORKOUT_LOGS=WorkoutLogs
VITE_AIRTABLE_TABLE_SCANS=MealScans
VITE_AIRTABLE_TABLE_USERS=Users
VITE_AIRTABLE_TABLE_TRAINER_NOTES=TrainerNotes
VITE_AIRTABLE_TABLE_LINKS=TrainerClientLink
VITE_AIRTABLE_TABLE_MESSAGES=Messages

# Nutrition lookup — Nutritionix dev tier (https://developer.nutritionix.com/)
# When unset, search falls back to a local Korean + Western foods catalog.
VITE_NUTRITIONIX_APP_ID=
VITE_NUTRITIONIX_APP_KEY=
